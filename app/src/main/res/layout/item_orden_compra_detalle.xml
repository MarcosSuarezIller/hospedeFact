<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/card_bg">

    <!-- Nombre -->
    <TextView
        android:id="@+id/text_item_orden_nombre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nombre Producto"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="4dp" />

    <!-- Fila: Cantidad, Precio, Subtotal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/text_item_orden_cantidad"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="10 un."
            android:textSize="12sp"
            android:textColor="#757575" />

        <TextView
            android:id="@+id/text_item_orden_precio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="€8.50"
            android:textSize="12sp"
            android:textColor="#2196F3"
            android:layout_marginRight="8dp" />

        <TextView
            android:id="@+id/text_item_orden_subtotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="€85.00"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginRight="8dp" />

        <Button
            android:id="@+id/btn_eliminar_item_orden"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="❌"
            android:textSize="12sp"
            android:paddingHorizontal="8dp"
            android:background="@color/danger_red"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>