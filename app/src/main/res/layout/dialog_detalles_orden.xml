<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Detalles de Orden"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2196F3"
        android:layout_marginBottom="16dp" />

    <!-- ID de Orden -->
    <TextView
        android:id="@+id/text_orden_id_detalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Orden #ABC123"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="4dp" />

    <!-- Proveedor -->
    <TextView
        android:id="@+id/text_proveedor_detalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Proveedor: Nombre"
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginBottom="4dp" />

    <!-- Fecha -->
    <TextView
        android:id="@+id/text_fecha_detalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Fecha: 11/04/2026"
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginBottom="16dp" />

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp" />

    <!-- Items -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Productos:"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_items_detalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp" />

    <!-- Total -->
    <TextView
        android:id="@+id/text_total_detalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Subtotal: €0.00\nIVA: €0.00\nTotal: €0.00"
        android:textSize="12sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="@drawable/card_bg"
        android:layout_marginBottom="16dp" />

    <!-- Botón cerrar -->
    <Button
        android:id="@+id/btn_cerrar_detalles"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cerrar"
        android:textSize="14sp"
        android:background="@color/button_color"
        android:textColor="#FFFFFF" />

</LinearLayout>