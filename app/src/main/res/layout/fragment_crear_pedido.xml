<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_atras_pedido"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:layout_marginRight="8dp"
            android:background="@color/button_color"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🍽️ Crear Pedido"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />
    </LinearLayout>

    <!-- Spinner de Huéspedes -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👤 Selecciona huésped:"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="4dp" />

    <!-- Spinner huesped -->
    <Spinner
        android:id="@+id/spinner_huesped"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/edit_text_bg" />

    <!-- Spinner Mesa -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mesa (Restauracion)"
        android:textSize="13sp"
        android:textColor="#757575"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_mesa"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/edit_text_bg"
        android:layout_marginBottom="12dp" />

    <!-- Sección Menú -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Menú disponible:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_menu"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar_pedido"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- Separador -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginVertical="8dp" />

    <!-- Sección Carrito -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🛒 Tu carrito:"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_carrito"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="8dp" />

    <!-- Total y Botón Crear -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/text_total"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Total: €0.00"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />

        <Button
            android:id="@+id/btn_crear_pedido"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Crear Pedido"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            android:background="@color/success_green"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>