<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/card_bg">

    <TextView
        android:id="@+id/text_admin_numero_habitacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Habitacion 1"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/text_admin_tipo_habitacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tipo: Doble"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/text_admin_precio_habitacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Precio noche: €80.00"
        android:textSize="12sp"
        android:textColor="#2196F3"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/text_admin_capacidad_habitacion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Capacidad: 2 personas"
        android:textSize="12sp"
        android:textColor="#757575"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btn_eliminar_habitacion_admin"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="Eliminar Habitacion"
        android:textSize="12sp"
        android:background="@color/danger_red"
        android:textColor="#FFFFFF" />

</LinearLayout>