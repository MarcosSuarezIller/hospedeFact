<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <!-- Header con título y botón atrás -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_atras"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:layout_marginRight="8dp"
            android:background="@color/button_color"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👥 Huéspedes Activos"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />
    </LinearLayout>

    <!-- Botón Nuevo Huésped -->
    <Button
        android:id="@+id/btn_nuevo_huesped"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="+ Nuevo Huésped"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"
        android:background="@color/success_green"
        android:textColor="#FFFFFF" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_huespedes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone" />

    <!-- Texto vacío -->
    <TextView
        android:id="@+id/text_vacio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="Cargando..."
        android:textAlignment="center"
        android:gravity="center"
        android:textColor="#757575"
        android:textSize="16sp" />

</LinearLayout>