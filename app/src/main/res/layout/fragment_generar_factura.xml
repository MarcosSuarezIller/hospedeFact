<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_atras_factura"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:layout_marginRight="8dp"
            android:background="@color/button_color"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📄 Generar Factura"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />
    </LinearLayout>

    <!-- Spinner de Huéspedes -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="👤 Selecciona huésped:"
        android:textSize="14sp"
        android:textColor="#757575"
        android:layout_marginBottom="4dp" />

    <Spinner
        android:id="@+id/spinner_huesped_factura"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/edit_text_bg" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar_factura"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:visibility="gone" />

    <!-- Resumen de Pedidos -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_resumen_pedidos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:typeface="monospace"
                android:textColor="#212121"
                android:padding="12dp"
                android:background="@drawable/card_bg"
                android:visibility="gone" />

            <TextView
                android:id="@+id/text_sin_pedidos"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Sin pedidos pendientes"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="#757575"
                android:textSize="16sp"
                android:padding="32dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Botón Generar -->
    <Button
        android:id="@+id/btn_generar_factura"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="✅ Generar Factura Consolidada"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@color/success_green"
        android:textColor="#FFFFFF"
        android:enabled="false" />

</LinearLayout>