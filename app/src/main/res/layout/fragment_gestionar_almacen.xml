<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FAFAFA">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btn_atras_almacen"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="←"
            android:textSize="20sp"
            android:layout_marginRight="8dp"
            android:background="@color/button_color"
            android:textColor="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📦 Gestionar Almacén"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3" />
    </LinearLayout>

    <!-- Estadísticas -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <TextView
            android:id="@+id/text_estadisticas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cargando estadísticas..."
            android:textSize="12sp"
            android:typeface="monospace"
            android:textColor="#212121"
            android:padding="12dp"
            android:background="@drawable/card_bg" />
    </ScrollView>

    <!-- Botones del menú -->
    <Button
        android:id="@+id/btn_productos"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📦 Gestionar Productos"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:background="@color/button_color"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_proveedores"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="🏢 Gestionar Proveedores"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:background="@color/button_color"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_ordenes"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📋 Órdenes de Compra"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:background="@color/button_color"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_alertas"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⚠️ Alertas de Stock"
        android:textSize="14sp"
        android:layout_marginBottom="8dp"
        android:background="@color/warning_orange"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btn_reportes"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📊 Reportes"
        android:textSize="14sp"
        android:background="@color/button_color"
        android:textColor="#FFFFFF" />

</LinearLayout>