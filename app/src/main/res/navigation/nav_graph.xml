<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- FRAGMENTO: LoginFragment -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.hospedefact.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">

        <!-- ACCIÓN: Login -> Dashboard -->
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- FRAGMENTO: DashboardFragment -->
    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.hospedefact.ui.dashboard.DashboardFragment"
        android:label="Dashboard"
        tools:layout="@layout/fragment_dashboard">

        <!-- ACCIÓN: Dashboard -> Huéspedes -->
        <action
            android:id="@+id/action_dashboard_to_huespedes"
            app:destination="@id/listaHuespedesFragment" />

        <!-- ACCIÓN: Dashboard -> Pedidos -->
        <action
            android:id="@+id/action_dashboard_to_pedidos"
            app:destination="@id/crearPedidoFragment" />

        <!-- ACCIÓN: Dashboard -> Mesas -->
        <action
            android:id="@+id/action_dashboard_to_admin_mesas"
            app:destination="@id/adminMesasFragment" />

        <!-- ACCIÓN: Dashboard -> Almacén -->
        <action
            android:id="@+id/action_dashboard_to_almacen"
            app:destination="@id/gestionarAlmacenFragment" />

        <!-- ACCIÓN: Dashboard -> Login (logout) -->
        <action
            android:id="@+id/action_dashboard_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />

        <!-- ACCIÓN: Dashboard -> Factura -->
        <action
            android:id="@+id/action_dashboard_to_factura"
            app:destination="@id/generarFacturaFragment" />


    </fragment>

    <!-- FRAGMENTO: ListaHuespedesFragment -->
    <fragment
        android:id="@+id/listaHuespedesFragment"
        android:name="com.example.hospedefact.ui.huespedes.ListaHuespedesFragment"
        android:label="Huéspedes"
        tools:layout="@layout/fragment_lista_huespedes">

        <!-- ACCIÓN: Huéspedes -> Dashboard -->
        <action
            android:id="@+id/action_huespedes_to_dashboard"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <!-- FRAGMENTO: CrearPedidoFragment -->
    <fragment
        android:id="@+id/crearPedidoFragment"
        android:name="com.example.hospedefact.ui.pedidos.CrearPedidoFragment"
        android:label="Crear Pedido"
        tools:layout="@layout/fragment_crear_pedido">

        <!-- ACCIÓN: Pedidos -> Dashboard -->
        <action
            android:id="@+id/action_pedidos_to_dashboard"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <!-- FRAGMENTO: GenerarFacturaFragment -->
    <fragment
        android:id="@+id/generarFacturaFragment"
        android:name="com.example.hospedefact.ui.factura.GenerarFacturaFragment"
        android:label="Generar Factura"
        tools:layout="@layout/fragment_generar_factura">

        <!-- ACCIÓN: Factura -> Dashboard -->
        <action
            android:id="@+id/action_factura_to_dashboard"
            app:destination="@id/dashboardFragment" />

        <!-- ACCIÓN: Factura -> Vista Factura -->
        <action
            android:id="@+id/action_generar_factura_to_vista"
            app:destination="@id/vistaFacturaFragment" />
    </fragment>

    <!-- FRAGMENTO: VistaFacturaFragment -->
    <fragment
        android:id="@+id/vistaFacturaFragment"
        android:name="com.example.hospedefact.ui.factura.VistaFacturaFragment"
        android:label="Vista Factura"
        tools:layout="@layout/fragment_vista_factura">

        <!-- ACCIÓN: Vista Factura -> Dashboard -->
        <action
            android:id="@+id/action_vista_factura_to_dashboard"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <!-- FRAGMENTO: GestionarAlmacenFragment -->
    <fragment
        android:id="@+id/gestionarAlmacenFragment"
        android:name="com.example.hospedefact.ui.almacen.GestionarAlmacenFragment"
        android:label="Almacén"
        tools:layout="@layout/fragment_gestionar_almacen">

        <action
            android:id="@+id/action_almacen_to_dashboard"
            app:destination="@id/dashboardFragment" />

        <action
            android:id="@+id/action_almacen_to_productos"
            app:destination="@id/listaProductosFragment" />

        <action
            android:id="@+id/action_almacen_to_proveedores"
            app:destination="@id/listaProveedoresFragment" />

        <action
            android:id="@+id/action_almacen_to_ordenes"
            app:destination="@id/listaOrdenesCompraFragment" />

        <action
            android:id="@+id/action_almacen_to_alertas"
            app:destination="@id/alertasStockFragment" />

        <action
            android:id="@+id/action_almacen_to_recepcion"
            app:destination="@id/recepcionMercanciaFragment" />
    </fragment>

    <!-- FRAGMENTO: ListaProductosFragment -->
    <fragment
        android:id="@+id/listaProductosFragment"
        android:name="com.example.hospedefact.ui.almacen.ListaProductosFragment"
        android:label="Productos"
        tools:layout="@layout/fragment_lista_productos">

        <action
            android:id="@+id/action_productos_to_almacen"
            app:destination="@id/gestionarAlmacenFragment" />
        <action
            android:id="@+id/action_productos_to_nuevo_producto"
            app:destination="@id/nuevoProductoFragment" />
    </fragment>

    <!-- FRAGMENTO: ListaProveedoresFragment -->
    <fragment
        android:id="@+id/listaProveedoresFragment"
        android:name="com.example.hospedefact.ui.almacen.ListaProveedoresFragment"
        android:label="Proveedores"
        tools:layout="@layout/fragment_lista_proveedores">

        <action
            android:id="@+id/action_proveedores_to_almacen"
            app:destination="@id/gestionarAlmacenFragment" />
        <action
            android:id="@+id/action_proveedores_to_nuevo_proveedor"
            app:destination="@id/nuevoProveedorFragment" />
    </fragment>

    <!-- FRAGMENTO: ListaOrdenesCompraFragment -->
    <fragment
        android:id="@+id/listaOrdenesCompraFragment"
        android:name="com.example.hospedefact.ui.almacen.ListaOrdenesCompraFragment"
        android:label="Órdenes"
        tools:layout="@layout/fragment_lista_ordenes_compra">

        <action
            android:id="@+id/action_ordenes_to_almacen"
            app:destination="@id/gestionarAlmacenFragment" />

        <action
            android:id="@+id/action_ordenes_to_crear_orden"
            app:destination="@id/crearOrdenCompraFragment" />
    </fragment>

    <!-- FRAGMENTO: AlertasStockFragment -->
    <fragment
        android:id="@+id/alertasStockFragment"
        android:name="com.example.hospedefact.ui.almacen.AlertasStockFragment"
        android:label="Alertas"
        tools:layout="@layout/fragment_alertas_stock">

        <action
            android:id="@+id/action_alertas_to_almacen"
            app:destination="@id/gestionarAlmacenFragment" />
    </fragment>

    <!-- FRAGMENTO: NuevoProductoFragment -->
    <fragment
        android:id="@+id/nuevoProductoFragment"
        android:name="com.example.hospedefact.ui.almacen.NuevoProductoFragment"
        android:label="Nuevo Producto"
        tools:layout="@layout/fragment_nuevo_producto">

        <action
            android:id="@+id/action_nuevo_producto_to_productos"
            app:destination="@id/listaProductosFragment" />
    </fragment>

    <!-- FRAGMENTO: NuevoProveedorFragment -->
    <fragment
        android:id="@+id/nuevoProveedorFragment"
        android:name="com.example.hospedefact.ui.almacen.NuevoProveedorFragment"
        android:label="Nuevo Proveedor"
        tools:layout="@layout/fragment_nuevo_proveedor">

        <action
            android:id="@+id/action_nuevo_proveedor_to_proveedores"
            app:destination="@id/listaProveedoresFragment" />
    </fragment>

    <!-- FRAGMENTO: CrearOrdenCompraFragment -->
    <fragment
        android:id="@+id/crearOrdenCompraFragment"
        android:name="com.example.hospedefact.ui.almacen.CrearOrdenCompraFragment"
        android:label="Crear Orden"
        tools:layout="@layout/fragment_crear_orden_compra">

        <action
            android:id="@+id/action_crear_orden_to_ordenes"
            app:destination="@id/listaOrdenesCompraFragment" />
    </fragment>

    <!-- FRAGMENTO: RecepcionMercanciaFragment -->
    <fragment
        android:id="@+id/recepcionMercanciaFragment"
        android:name="com.example.hospedefact.ui.almacen.RecepcionMercanciaFragment"
        android:label="Recepción"
        tools:layout="@layout/fragment_recepcion_mercancia">

        <action
            android:id="@+id/action_recepcion_to_almacen"
            app:destination="@id/gestionarAlmacenFragment" />
    </fragment>
    <!-- FRAGMENTO: MesasFragment -->
    <fragment
        android:id="@+id/adminMesasFragment"
        android:name="com.example.hospedefact.ui.restauracion.AdminMesasFragment"
        android:label="Admin Mesas"
        tools:layout="@layout/fragment_admin_mesas">

        <action
            android:id="@+id/action_admin_mesas_to_dashboard"
            app:destination="@id/dashboardFragment" />
    </fragment>

</navigation>